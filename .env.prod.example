# ─── 서버 배포용 env (Linux) ─────────────────────────────────────────────────
# 복사: cp .env.prod.example .env.prod
# 실행: docker compose -f docker-compose.prod.yml --env-file .env.prod up --build -d

ENV_FILE=.env.prod

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_USER=pubg
DB_PASSWORD=your_strong_password_here
DB_NAME=pubg_analyzer

# ─── PUBG API ────────────────────────────────────────────────────────────────
PUBG_API_KEY=your_pubg_api_key_here

# ─── Claude CLI 인증 경로 (Linux) ────────────────────────────────────────────
# claude CLI가 인증된 서버 유저의 홈 디렉토리
CLAUDE_CREDENTIALS_PATH=/home/risker/.claude

# ─── 관리자 (T-018, 선택) ────────────────────────────────────────────────────
ADMIN_PASSWORD=your_admin_password_here

# ─── 캐시 TTL ────────────────────────────────────────────────────────────────
ANALYSIS_CACHE_TTL_HOURS=24

# ─── API URL 설정 ────────────────────────────────────────────────────────────
# 서버사이드 SSR용 (Docker 내부 네트워크, Next.js → API 직접 통신)
API_URL=http://api:8081
# 클라이언트사이드용 (브라우저 → Caddy → API, /api 없이 도메인만)
NEXT_PUBLIC_API_URL=https://pubg.risker.co.kr
