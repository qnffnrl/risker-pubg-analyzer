# ─── PostgreSQL ─────────────────────────────────────────────────────────────
DB_USER=pubg
DB_PASSWORD=your_strong_password_here
DB_NAME=pubg_analyzer

# ─── PUBG API ────────────────────────────────────────────────────────────────
PUBG_API_KEY=your_pubg_api_key_here

# ─── Anthropic (T-011 LLM 요약, 선택) ──────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── 관리자 (T-018, 선택) ───────────────────────────────────────────────────
ADMIN_PASSWORD=your_admin_password_here

# ─── 캐시 TTL (선택, 기본값: 24시간) ────────────────────────────────────────
ANALYSIS_CACHE_TTL_HOURS=24

# ─── 프론트엔드 API URL ──────────────────────────────────────────────────────
# 로컬 Docker 테스트: http://localhost:8081
# 프로덕션 배포 시: https://pubg.risker.co.kr/api
NEXT_PUBLIC_API_URL=http://localhost:8081
