# ─── 로컬 Docker 테스트용 env (Windows) ─────────────────────────────────────
# 복사: cp .env.local.example .env.local
# 실행: docker compose -f docker-compose.prod.yml --env-file .env.local up --build -d

ENV_FILE=.env.local

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_USER=pubg
DB_PASSWORD=localpassword
DB_NAME=pubg_analyzer

# ─── PUBG API ────────────────────────────────────────────────────────────────
PUBG_API_KEY=your_pubg_api_key_here

# ─── Claude CLI 인증 경로 (Windows) ──────────────────────────────────────────
# Docker Desktop이 Windows 경로를 자동 변환함 (슬래시 사용)
CLAUDE_CREDENTIALS_PATH=C:/Users/your-username/.claude

# ─── 관리자 (T-018, 선택) ────────────────────────────────────────────────────
ADMIN_PASSWORD=localadmin

# ─── 캐시 TTL ────────────────────────────────────────────────────────────────
ANALYSIS_CACHE_TTL_HOURS=24

# ─── 프론트엔드 API URL (브라우저에서 접근하는 주소) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8081
