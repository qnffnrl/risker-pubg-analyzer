# ============================================================
# PUBG Analyzer — 환경 변수 예시
# 이 파일을 복사해 .env 로 만들고 실제 값을 채워주세요.
# ============================================================

# ─── PUBG API ────────────────────────────────────────────────
# Krafton Developer Portal: https://developer.pubg.com/
PUBG_API_KEY=your_pubg_api_key_here

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://pubg:pubg@localhost:5432/pubg_analyzer

# ─── Redis (BullMQ broker) ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret

# ─── LLM (Claude — optional, 자연어 성향 요약) ───────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development

# apps/api
PORT=3001

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:3001

# apps/worker — Bull Board UI port
BULL_BOARD_PORT=3002
