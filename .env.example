# PUBG API (Krafton Developer Portal: https://developer.pubg.com/)
PUBG_API_KEY=your_pubg_api_key_here

# Database
DATABASE_URL=postgresql://pubg:pubg@localhost:5432/pubg_analyzer

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_random_secret

# LLM (Claude — optional, for natural language play style descriptions)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
